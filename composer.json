{
    "name": "16bitsrl/fattureincloud-cli",
    "description": "Comprehensive CLI for Fatture in Cloud API - built for humans and agents.",
    "keywords": ["fattureincloud", "invoicing", "e-invoice", "cli", "api", "fattura", "italia"],
    "homepage": "https://github.com/16bitsrl/fattureincloud-cli",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/16bitsrl/fattureincloud-cli/issues",
        "source": "https://github.com/16bitsrl/fattureincloud-cli"
    },
    "authors": [
        {
            "name": "16bit S.r.l.",
            "email": "dev@16bit.ai"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/http": "^12.55",
        "laravel-zero/framework": "^12.0.2",
        "spatie/laravel-openapi-cli": "^1.0"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/fic"]
}
