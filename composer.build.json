{
    "name": "16bitsrl/fattureincloud-cli-build",
    "description": "Build-time manifest for the Fatture in Cloud CLI PHAR.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/http": "^12.55",
        "laravel-zero/framework": "^12.0.2",
        "spatie/laravel-openapi-cli": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
